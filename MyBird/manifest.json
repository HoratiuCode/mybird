{
  "manifest_version": 3,
  "name": "MyBird",
  "description": "Save keywords and search live X posts from a clean popup dashboard.",
  "version": "1.0.0",
  "action": {
    "default_title": "MyBird",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/mybird.svg",
      "32": "icons/mybird.svg",
      "48": "icons/mybird.svg",
      "128": "icons/mybird.svg"
    }
  },
  "icons": {
    "16": "icons/mybird.svg",
    "32": "icons/mybird.svg",
    "48": "icons/mybird.svg",
    "128": "icons/mybird.svg"
  },
  "permissions": [
    "storage"
  ]
}
